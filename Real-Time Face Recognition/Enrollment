"""
EnrollmentSession – interactive face enrollment via webcam.

States
──────
  countdown  →  capturing  →  done

During "countdown" a 3-2-1 overlay is shown so the user can position themselves.
During "capturing" frames are sampled at regular intervals, with a flash effect.
"""

import time
import logging
from enum import Enum, auto
from typing import List

import cv2
import numpy as np

logger = logging.getLogger(__name__)


class _State(Enum):
    COUNTDOWN  = auto()
    CAPTURING  = auto()
    DONE       = auto()


class EnrollmentSession:
    """Stateful enrollment session; call `process_frame` each camera tick."""

    _CAPTURE_EVERY = 12   # sample every N frames during capturing phase

    def __init__(self, name: str, samples: int = 5, countdown: int = 3) -> None:
        self.name       = name
        self.samples    = samples
        self.countdown  = countdown
        self._state     = _State.COUNTDOWN
        self._t_start: float = 0.0
        self._frame_n   = 0
        self._frames: List[np.ndarray] = []

    # ── Public API ────────────────────────────────────────────────────────────

    def process_frame(self, frame: np.ndarray) -> np.ndarray:
        """Overlay enrollment UI on *frame* and capture samples. Returns annotated frame."""
        if self._state == _State.COUNTDOWN:
            frame = self._phase_countdown(frame)
        elif self._state == _State.CAPTURING:
            frame = self._phase_capturing(frame)
        else:
            frame = self._phase_done(frame)
        return frame

    @property
    def is_done(self) -> bool:
        return self._state == _State.DONE

    @property
    def captured_frames(self) -> List[np.ndarray]:
        return list(self._frames)

    # ── State handlers ────────────────────────────────────────────────────────

    def _phase_countdown(self, frame: np.ndarray) -> np.ndarray:
        if self._t_start == 0.0:
            self._t_start = time.perf_counter()

        remaining = self.countdown - int(time.perf_counter() - self._t_start)
        if remaining <= 0:
            self._state  = _State.CAPTURING
            self._t_start = 0.0
            return frame

        h, w = frame.shape[:2]
        overlay = frame.copy()
        cv2.rectangle(overlay, (0, 0), (w, h), (0, 0, 0), -1)
        cv2.addWeighted(overlay, 0.45, frame, 0.55, 0, frame)

        self._text(frame, f"Enrolling:  {self.name}",
                   (w // 2, h // 2 - 70), scale=1.0, color=(255, 255, 255))
        self._text(frame, "Position your face and hold still",
                   (w // 2, h // 2 - 28), scale=0.6, color=(180, 180, 180))
        self._text(frame, str(remaining),
                   (w // 2, h // 2 + 68), scale=4.0, color=(0, 220, 80), thickness=5)
        return frame

    def _phase_capturing(self, frame: np.ndarray) -> np.ndarray:
        self._frame_n += 1

        # Sample a frame
        if self._frame_n % self._CAPTURE_EVERY == 0:
            self._frames.append(frame.copy())
            logger.debug("Captured sample %d/%d", len(self._frames), self.samples)

        if len(self._frames) >= self.samples:
            self._state = _State.DONE
            return frame

        h, w  = frame.shape[:2]
        ratio = len(self._frames) / self.samples

        # Flash effect right after a capture
        if self._frame_n % self._CAPTURE_EVERY < 4:
            flash = np.full_like(frame, 255)
            cv2.addWeighted(flash, 0.25, frame, 0.75, 0, frame)

        # Progress bar
        bw, bh, bx, by = 420, 18, (w - 420) // 2, h - 54
        cv2.rectangle(frame, (bx, by), (bx + bw, by + bh), (40, 40, 40), -1)
        cv2.rectangle(frame, (bx, by), (bx + int(bw * ratio), by + bh), (0, 220, 80), -1)
        self._text(frame, f"Capturing …  {len(self._frames)} / {self.samples}",
                   (w // 2, by - 10), scale=0.65, color=(220, 220, 220))
        return frame

    def _phase_done(self, frame: np.ndarray) -> np.ndarray:
        h, w = frame.shape[:2]
        self._text(frame, "Enrollment complete!",
                   (w // 2, h // 2), scale=1.1, color=(0, 220, 80), thickness=2)
        return frame

    # ── Helpers ───────────────────────────────────────────────────────────────

    @staticmethod
    def _text(
        frame: np.ndarray,
        text: str,
        center: tuple,
        scale: float = 0.75,
        color=(255, 255, 255),
        thickness: int = 1,
    ) -> None:
        font = cv2.FONT_HERSHEY_DUPLEX
        (tw, th), _ = cv2.getTextSize(text, font, scale, thickness)
        ox, oy = center[0] - tw // 2, center[1] + th // 2
        cv2.putText(frame, text, (ox, oy), font, scale, color, thickness, cv2.LINE_AA)